# run `cp .env.example .env.local`

# All of these are optional. When set, they preload a brand-new invoice with
# your seller/buyer details and default item price (see src/app/(app)/page.tsx
# and src/env.ts). Existing invoices saved in localStorage are never overwritten.

# Seller info
SELLER_NAME="Adam Smith"
SELLER_ADDRESS="London, UK"
SELLER_VAT_NO="12345"
SELLER_EMAIL="seller@mail.com"
SELLER_ACCOUNT_NUMBER="12345"
SELLER_SWIFT_BIC="12345"

# Buyer info
BUYER_NAME="Random Company"
BUYER_ADDRESS="Bristol, UK"
BUYER_VAT_NO="12345"
BUYER_EMAIL="buyer@mail.com"

# Default price for the first invoice item
INVOICE_NET_PRICE="10000"