# run `cp .env.example .env.local`

# All of these are optional. This app is statically exported (no server), so
# these NEXT_PUBLIC_* values get compiled directly into the JS bundle when you
# run `npm run build` — set them BEFORE building. On first load in the
# browser, they seed a brand-new invoice and get written to localStorage.
# Existing invoices already saved in localStorage are never overwritten.

# Seller info
NEXT_PUBLIC_SELLER_NAME="Adam Smith"
NEXT_PUBLIC_SELLER_ADDRESS="London, UK"
NEXT_PUBLIC_SELLER_VAT_NO="12345"
NEXT_PUBLIC_SELLER_EMAIL="seller@mail.com"
NEXT_PUBLIC_SELLER_ACCOUNT_NUMBER="12345"
NEXT_PUBLIC_SELLER_SWIFT_BIC="12345"

# Buyer info
NEXT_PUBLIC_BUYER_NAME="Random Company"
NEXT_PUBLIC_BUYER_ADDRESS="Bristol, UK"
NEXT_PUBLIC_BUYER_VAT_NO="12345"
NEXT_PUBLIC_BUYER_EMAIL="buyer@mail.com"

# Default price for the first invoice item
NEXT_PUBLIC_INVOICE_NET_PRICE="10000"
